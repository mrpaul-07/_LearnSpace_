# ============================================================
# LearnSpace Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# === Required ===
PORT=5000
NODE_ENV=development

# MongoDB connection — local or Atlas URI
MONGODB_URI=mongodb://localhost:27017/learnspace

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# URLs (used by SSLCommerz callbacks and CORS)
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# === Optional — SSLCommerz (real payments for Bangladesh) ===
# Sign up free at https://developer.sslcommerz.com/
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_LIVE=false

# === Optional — Cloudinary (cloud file storage) ===
# Without these, files are stored in ./uploads/ folder locally
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Optional — Email (for instructor approval / password reset notifications) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@learnspace.com

# === Optional — Stripe (international payments) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
