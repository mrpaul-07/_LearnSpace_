# ============================================================
# LearnSpace - .gitignore
# ============================================================

# ── Environment (NEVER push these!) ────────────────────────
.env
.env.local
.env.production
.env.development
.env.test

# ── Dependencies ───────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── User Uploaded Files (keep folder structure via .gitkeep) ──
backend/uploads/*
!backend/uploads/*/
backend/uploads/*/*
!backend/uploads/*/.gitkeep

# ── Frontend Build Output ───────────────────────────────────
frontend/build/
frontend/dist/

# ── Logs ───────────────────────────────────────────────────
logs/
backend/logs/*
!backend/logs/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Cache ──────────────────────────────────────────────────
.cache/
frontend/.cache/
backend/.cache/
*.tsbuildinfo

# ── Testing & Coverage ─────────────────────────────────────
coverage/
frontend/coverage/
backend/coverage/

# ── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ── Docker ─────────────────────────────────────────────────
docker-compose.override.yml